<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link rel="stylesheet" href="styles.css">
</head>

<body>

<div class="form-container">
    <form id="registerForm">
        <h1>Register</h1>

        <label>Name:</label><br>
        <input type="text" id="name" placeholder="Enter Name" required><br><br>

        <label>Email:</label><br>
        <input type="email" id="regEmail" placeholder="Enter Email" required><br><br>

        <label>Password:</label><br>
        <input type="password" id="regPassword" placeholder="Enter Password" required><br><br>

        <button type="submit">Register</button>
    </form>
</div>

<script src="script.js"></script>

</body>
</
